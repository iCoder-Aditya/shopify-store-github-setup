<script>
  (function() {
    class ProductTabs{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.tabs = this.querySelectorAll('[role="tab"]');
        this.panels = this.querySelectorAll('[role="tabpanel"]');
        
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.tabs.forEach((tab) => {
          tab.addEventListener('click', () => {
            this.switchTab(tab);
          });

          tab.addEventListener('keydown', (e) => {
            this.handleKeyboard(e, tab);
          });
        });
      }

      switchTab(selectedTab) {
        this.tabs.forEach((tab) => {
          tab.setAttribute('aria-selected', 'false');
        });

        this.panels.forEach((panel) => {
          panel.setAttribute('aria-hidden', 'true');
        });

        selectedTab.setAttribute('aria-selected', 'true');
        
        const panelId = selectedTab.getAttribute('aria-controls');
        const selectedPanel = this.querySelector(`#${panelId}`);
        
        if (selectedPanel) {
          selectedPanel.setAttribute('aria-hidden', 'false');
        }
      }

      handleKeyboard(e, currentTab) {
        const tabsArray = Array.from(this.tabs);
        const currentIndex = tabsArray.indexOf(currentTab);

        let newIndex;

        if (e.key === 'ArrowRight') {
          e.preventDefault();
          newIndex = currentIndex + 1;
          if (newIndex >= tabsArray.length) {
            newIndex = 0;
          }
        } else if (e.key === 'ArrowLeft') {
          e.preventDefault();
          newIndex = currentIndex - 1;
          if (newIndex < 0) {
            newIndex = tabsArray.length - 1;
          }
        } else if (e.key === 'Home') {
          e.preventDefault();
          newIndex = 0;
        } else if (e.key === 'End') {
          e.preventDefault();
          newIndex = tabsArray.length - 1;
        }

        if (newIndex !== undefined) {
          tabsArray[newIndex].focus();
          this.switchTab(tabsArray[newIndex]);
        }
      }
    }

    customElements.define('product-tabs-{{ ai_gen_id }}', ProductTabs{{ ai_gen_id }});
  })();
</script>

