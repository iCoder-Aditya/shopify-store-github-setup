{% doc %}
  @prompt
    generate a tab section for product description , why choose this , all ingredient , additional information, tab description should also has image list and banners to show graphics and images with key points 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-tabs-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-product-tabs__tab-list-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.tab_spacing }}px;
    border-bottom: {{ block.settings.tab_border_thickness }}px solid {{ block.settings.tab_border_color }};
    margin-bottom: {{ block.settings.content_spacing }}px;
    flex-wrap: wrap;
  }

  .ai-product-tabs__tab-button-{{ ai_gen_id }} {
    background: none;
    border: none;
    padding: {{ block.settings.tab_padding_vertical }}px {{ block.settings.tab_padding_horizontal }}px;
    cursor: pointer;
    font-size: {{ block.settings.tab_font_size }}px;
    color: {{ block.settings.tab_text_color }};
    position: relative;
    transition: color 0.3s ease;
    font-family: inherit;
  }

  .ai-product-tabs__tab-button-{{ ai_gen_id }}:hover {
    color: {{ block.settings.tab_hover_color }};
  }

  .ai-product-tabs__tab-button-{{ ai_gen_id }}[aria-selected="true"] {
    color: {{ block.settings.tab_active_color }};
    font-weight: 600;
  }

  .ai-product-tabs__tab-button-{{ ai_gen_id }}[aria-selected="true"]::after {
    content: '';
    position: absolute;
    bottom: calc(-1 * {{ block.settings.tab_border_thickness }}px);
    left: 0;
    right: 0;
    height: {{ block.settings.active_indicator_height }}px;
    background-color: {{ block.settings.tab_active_color }};
  }

  .ai-product-tabs__panel-{{ ai_gen_id }} {
    display: none;
    padding: {{ block.settings.panel_padding }}px;
    background-color: {{ block.settings.panel_background_color }};
    border-radius: {{ block.settings.panel_border_radius }}px;
    color: {{ block.settings.panel_text_color }};
    line-height: 1.6;
  }

  .ai-product-tabs__panel-{{ ai_gen_id }}[aria-hidden="false"] {
    display: block;
  }

  .ai-product-tabs__panel-{{ ai_gen_id }} h3 {
    margin-top: 0;
    margin-bottom: 12px;
    font-size: {{ block.settings.panel_heading_size }}px;
  }

  .ai-product-tabs__panel-{{ ai_gen_id }} p {
    margin: 0 0 12px;
  }

  .ai-product-tabs__panel-{{ ai_gen_id }} ul,
  .ai-product-tabs__panel-{{ ai_gen_id }} ol {
    margin: 0 0 12px;
    padding-left: 20px;
  }

  .ai-product-tabs__panel-{{ ai_gen_id }} li {
    margin-bottom: 8px;
  }

  .ai-product-tabs__image-list-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax({{ block.settings.image_list_min_width }}px, 1fr));
    gap: {{ block.settings.image_list_gap }}px;
    margin: {{ block.settings.image_list_margin }}px 0;
  }

  .ai-product-tabs__image-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.image_item_gap }}px;
    text-align: {{ block.settings.image_text_alignment }};
  }

  .ai-product-tabs__image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-product-tabs__image-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-product-tabs__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-product-tabs__image-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .ai-product-tabs__image-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.image_title_size }}px;
    font-weight: 600;
    margin: 0;
    color: {{ block.settings.panel_text_color }};
  }

  .ai-product-tabs__image-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.image_text_size }}px;
    margin: 0;
    color: {{ block.settings.panel_text_color }};
  }

  .ai-product-tabs__banner-{{ ai_gen_id }} {
    margin: {{ block.settings.banner_margin }}px 0;
    border-radius: {{ block.settings.banner_border_radius }}px;
    overflow: hidden;
    position: relative;
  }

  .ai-product-tabs__banner-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-product-tabs__banner-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 3 / 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-product-tabs__banner-placeholder-{{ ai_gen_id }} svg {
    width: 30%;
    height: 30%;
    opacity: 0.3;
  }

  @media screen and (max-width: 749px) {
    .ai-product-tabs__tab-list-{{ ai_gen_id }} {
      gap: {{ block.settings.tab_spacing | times: 0.5 }}px;
    }

    .ai-product-tabs__tab-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.tab_font_size | times: 0.9 }}px;
      padding: {{ block.settings.tab_padding_vertical | times: 0.8 }}px {{ block.settings.tab_padding_horizontal | times: 0.8 }}px;
    }

    .ai-product-tabs__panel-{{ ai_gen_id }} {
      padding: {{ block.settings.panel_padding | times: 0.7 }}px;
    }

    .ai-product-tabs__image-list-{{ ai_gen_id }} {
      grid-template-columns: repeat(auto-fit, minmax({{ block.settings.image_list_min_width | times: 0.7 }}px, 1fr));
    }
  }
{% endstyle %}

